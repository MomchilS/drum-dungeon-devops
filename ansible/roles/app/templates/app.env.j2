# Managed by Ansible
ENV={{ app_env | default('production') }}
SESSION_SECRET_KEY={{ session_secret_key }}
PRACTICE_DATA_DIR={{ app_data_dir | default('/opt/app/practice_data') }}

DB_HOST={{ db_host }}
DB_PORT={{ db_port }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASS={{ db_password }}
DATABASE_URL=postgresql+psycopg2://{{ db_user }}:{{ db_password }}@{{ db_host }}:{{ db_port }}/{{ db_name }}
